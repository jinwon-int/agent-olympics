node_modules/
*.tgz
.tmp/

# Round engine — auto-generated run directories
runs/

# Score engine — auto-generated judge records and scoreboard
results/*-auto-judge.yaml
results/scoreboard.json

# Longitudinal measurement — real round snapshots under results/longitudinal/
# are the durable over-time record and ARE committed (not ignored). Only scratch
# snapshots written to a tmp/scratch subdir are kept out of the tree.
results/longitudinal/scratch/

# perf-harness — auto-generated multi-iteration reports
results/perf-harness-report-*.json
results/perf-harness-report-*.yaml

# harness-to-packet — auto-generated v2 result packets
results/pkt-harness-*.yaml

# Web result consumer — generated output directories
web-output/

# Oracle privacy (#256): Season 001 keys are public reference/spent material and
# stay committed. From Season 002 onward, oracle answer keys and judge notes are
# a PRIVATE pipeline held out-of-repo — block them from being committed here.
# See docs/season-001-reference-tier.md.
oracle/season-002/
oracle/season-0[3-9]*/
docs/judge-notes-season-0[2-9]*.md

# OS files
*.DS_Store
Thumbs.db

# dry-run-gates — auto-generated finalizer evidence
evidence/dry-run/finalizer-evidence.json
