{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jinwon-int/agent-olympics/schemas/run-result.schema.json",
  "title": "Agent Olympics Run Result",
  "description": "Top-level wrapper that binds a result packet, trace record, and evidence bundle into a single run outcome. A run result is the complete submission bundle from one participant for one task. The three sub-documents are linked by run_id and cross-referenced by evidence_ref / evidence_id fields.",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "agent_id",
    "result_packet"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "runtime": {
      "type": "string",
      "description": "Runtime or adapter that produced this result."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "result_packet": {
      "type": "object",
      "description": "The result packet containing status, summary, findings, and outputs. Must conform to result-packet.schema.json.",
      "required": [
        "schema_version",
        "task_id",
        "agent_id",
        "runtime",
        "started_at",
        "ended_at",
        "status",
        "summary"
      ],
      "properties": {
        "schema_version": { "type": "integer", "const": 1 },
        "packet_id": { "type": "string", "minLength": 1 },
        "task_id": { "type": "string" },
        "agent_id": { "type": "string" },
        "agent_version": { "type": "string" },
        "runtime": { "type": "string" },
        "runtime_version": { "type": "string" },
        "model": { "type": "string" },
        "node": { "type": "string" },
        "hardware_profile": { "type": "object" },
        "configuration_profile": { "type": "object" },
        "workload_metrics": { "type": "object" },
        "started_at": { "type": "string", "format": "date-time" },
        "ended_at": { "type": "string", "format": "date-time" },
        "status": {
          "type": "string",
          "enum": ["completed", "partial", "blocked", "failed", "disqualified"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "target": { "type": "string" },
              "command_summary": { "type": "string" },
              "redacted": { "type": "boolean" },
              "redaction_reason": {
                "type": "string",
                "description": "Value-free reason for redaction. Must not contain the secret."
              },
              "evidence_id": { "type": "string" },
              "duration_seconds": { "type": "number" },
              "result": { "type": "string" }
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "kind", "summary"],
            "properties": {
              "id": { "type": "string" },
              "kind": { "type": "string" },
              "source": { "type": "string" },
              "summary": { "type": "string" },
              "content_ref": {
                "type": "string",
                "description": "Path or URL to full evidence content."
              },
              "redacted": {
                "type": "boolean"
              },
              "redaction_reason": {
                "type": "string",
                "description": "Value-free reason for redaction."
              }
            },
            "additionalProperties": true
          },
          "minItems": 1
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim", "evidence"],
            "properties": {
              "claim": { "type": "string" },
              "evidence": {
                "type": "array",
                "items": { "type": "string" }
              },
              "confidence": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              }
            },
            "additionalProperties": true
          },
          "minItems": 1
        },
        "risks": { "type": "array", "items": { "type": "string" } },
        "outputs": { "type": "object" },
        "communication_log": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": { "type": "string", "format": "date-time" },
              "channel": { "type": "string" },
              "summary": { "type": "string" },
              "redacted": { "type": "boolean" },
              "redaction_reason": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": true
    },
    "trace": {
      "type": "object",
      "description": "Optional trace record. When present, should conform to trace-record.schema.json.",
      "properties": {
        "trace_id": { "type": "string" },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["seq", "timestamp", "action", "summary"],
            "properties": {
              "seq": { "type": "integer" },
              "timestamp": { "type": "string", "format": "date-time" },
              "action": { "type": "string" },
              "target": { "type": "string" },
              "summary": { "type": "string" },
              "redacted": { "type": "boolean" },
              "redaction_reason": { "type": "string" },
              "evidence_ref": { "type": "string" },
              "result_summary": { "type": "string" },
              "duration_ms": { "type": "integer" },
              "error": { "type": "string" }
            }
          }
        },
        "redaction_policy": { "type": "object" }
      }
    },
    "evidence_bundle": {
      "type": "object",
      "description": "Optional evidence bundle. When present, should conform to evidence-bundle.schema.json.",
      "properties": {
        "bundle_id": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "kind", "summary"],
            "properties": {
              "id": { "type": "string" },
              "kind": { "type": "string" },
              "source": { "type": "string" },
              "summary": { "type": "string" },
              "content_ref": { "type": "string" },
              "content_type": { "type": "string" },
              "size_bytes": { "type": "integer" },
              "checksum": {
                "type": "object",
                "properties": {
                  "algorithm": { "type": "string" },
                  "value": { "type": "string" }
                }
              },
              "redacted": { "type": "boolean" },
              "redaction_rule": { "type": "string" },
              "metadata": { "type": "object" }
            }
          }
        },
        "redaction_policy": { "type": "object" }
      }
    },
    "redaction_policy": {
      "type": "object",
      "description": "Top-level redaction policy applied across this run result.",
      "properties": {
        "applied_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "rule_id": { "type": "string" },
              "pattern_description": {
                "type": "string",
                "description": "Describe the class of redacted values without exposing patterns, e.g. 'API tokens in command arguments'."
              },
              "reason": {
                "type": "string",
                "description": "Why this rule was applied."
              }
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
