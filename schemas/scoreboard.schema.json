{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jinwon-int/agent-olympics/schemas/scoreboard.schema.json",
  "title": "Agent Olympics Scoreboard",
  "description": "Aggregated scoreboard for an Agent Olympics round. Lists each participant-task combination with validation status, automated judge record references, and pending human/blind-judge dimensions. Scoreboard is the final output of the round engine's judge lane.",
  "type": "object",
  "required": [
    "schema_version",
    "scoreboard_id",
    "round_id",
    "generated_at",
    "participants",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Scoreboard schema version."
    },
    "schema_description": {
      "type": "string",
      "description": "Human-readable description of this schema version."
    },
    "scoreboard_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique scoreboard identifier, typically matching the round ID."
    },
    "round_id": {
      "type": "string",
      "minLength": 1,
      "description": "The round this scoreboard belongs to."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this scoreboard was generated."
    },
    "generated_by": {
      "type": "string",
      "description": "Tool or agent that generated the scoreboard, e.g. 'score.js v1'."
    },
    "oracle_ref": {
      "type": "string",
      "description": "Path to the oracle/answer key file used for comparison scoring. Only set when oracle-based checks were applied."
    },

    "participants": {
      "type": "array",
      "description": "List of participants in the round with their metadata. Deduplicated by agent_id.",
      "items": {
        "type": "object",
        "required": ["agent_id"],
        "properties": {
          "agent_id": { "type": "string", "minLength": 1 },
          "runtime": { "type": "string" },
          "model": { "type": "string" },
          "node": { "type": "string" }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },

    "entries": {
      "type": "array",
      "description": "One entry per participant-task combo. Each entry captures validation results, automated judge record, and pending scoring dimensions.",
      "items": {
        "type": "object",
        "required": [
          "entry_id",
          "task_id",
          "agent_id",
          "run_id",
          "packet_id",
          "status"
        ],
        "properties": {
          "entry_id": { "type": "string", "minLength": 1 },
          "task_id": { "type": "string", "minLength": 1 },
          "agent_id": { "type": "string", "minLength": 1 },
          "run_id": { "type": "string", "minLength": 1 },
          "packet_id": { "type": "string", "minLength": 1 },
          "packet_ref": {
            "type": "string",
            "description": "Relative path to the result packet file."
          },

          "status": {
            "type": "string",
            "enum": ["completed", "partial", "blocked", "failed", "disqualified"],
            "description": "Participant-reported status from the result packet."
          },

          "schema_validation": {
            "type": "object",
            "description": "Result of validating the packet against its JSON schema.",
            "required": ["valid"],
            "properties": {
              "valid": { "type": "boolean" },
              "schema": { "type": "string", "description": "Schema ID used for validation." },
              "errors": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },

          "semantic_checks": {
            "type": "object",
            "description": "Cross-field semantic validation results.",
            "required": ["passed"],
            "properties": {
              "passed": { "type": "boolean" },
              "warnings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              },
              "errors": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "field": { "type": "string" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          },

          "presence_checks": {
            "type": "object",
            "description": "Verification that required outputs and evidence fields are populated.",
            "required": ["all_required_outputs_present"],
            "properties": {
              "all_required_outputs_present": { "type": "boolean" },
              "missing_outputs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "evidence_count": { "type": "integer", "minimum": 0 },
              "finding_count": { "type": "integer", "minimum": 0 }
            }
          },

          "judge_record_ref": {
            "type": "string",
            "description": "Relative path to the judge record file for this entry, if one exists or was auto-generated."
          },
          "judge_type": {
            "type": "string",
            "enum": ["automated", "human", "llm-assisted", "hybrid", "pending"],
            "description": "Type of judging applied. 'pending' means no judge record has been produced yet and the entry awaits human or blind review."
          },

          "score": {
            "type": "object",
            "description": "Score summary from the judge record, or null if judging is pending.",
            "properties": {
              "total_score": { "type": "number" },
              "verdict": {
                "type": "string",
                "enum": ["pass", "conditional_pass", "fail", "disqualification"]
              },
              "dimensions": {
                "type": "object",
                "description": "Per-dimension scores from the judge record.",
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "score": { "type": "number" },
                    "max": { "type": "number" }
                  }
                }
              }
            }
          },

          "pending_dimensions": {
            "type": "array",
            "description": "Score dimensions that still require human or blind-judge scoring. Automated dimension names are NOT listed here — only dimensions gated on manual review.",
            "items": {
              "type": "string"
            }
          },

          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          },

          "errors": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },

    "summary": {
      "type": "object",
      "description": "Round-level summary statistics.",
      "properties": {
        "total_participants": { "type": "integer" },
        "total_entries": { "type": "integer" },
        "entries_with_judge": { "type": "integer", "description": "Entries that have at least one judge record (automated or human)." },
        "entries_pending_human_judge": { "type": "integer", "description": "Entries still requiring human/blind-judge review." },
        "entries_with_errors": { "type": "integer", "description": "Entries that have schema or semantic errors." },
        "automated_checks": {
          "type": "integer",
          "description": "Count of checks that ran automatically (schema validation, cross-field semantics, presence checks)."
        },
        "pending_checks": {
          "type": "integer",
          "description": "Count of scoring dimensions gated on human or blind-judge review."
        }
      }
    }
  },
  "additionalProperties": false
}
