{
  "$id": "https://github.com/jinwon-int/agent-olympics/schemas/run-claim.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run Claim",
  "description": "Idempotent claim of a task/run on the HTTP/JSON participation surface (POST /runs). The request is participant-authored; the response is server-issued. See docs/http-json-participant-protocol.md. The Idempotency-Key header (not modelled here) makes duplicate claims safe.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/claim_request" },
    { "$ref": "#/$defs/claim_response" }
  ],
  "$defs": {
    "claim_request": {
      "type": "object",
      "required": ["kind", "schema_version", "participant_id", "round_id", "task_id", "mode"],
      "properties": {
        "kind": { "const": "claim_request" },
        "schema_version": { "type": "integer", "const": 1 },
        "participant_id": { "type": "string", "minLength": 1 },
        "round_id": { "type": "string", "minLength": 1 },
        "task_id": { "type": "string", "minLength": 1 },
        "mode": {
          "type": "string",
          "enum": ["source_only"],
          "description": "Only source_only is defined. It must not imply GitHub writes, deploys, restarts, provider sends, DB mutation, releases, or secret movement."
        }
      },
      "additionalProperties": false
    },
    "claim_response": {
      "type": "object",
      "required": ["kind", "schema_version", "run_id", "required_artifacts", "forbidden_actions"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["claim_response", "already_claimed"]
        },
        "schema_version": { "type": "integer", "const": 1 },
        "run_id": { "type": "string", "minLength": 1 },
        "task_envelope_ref": {
          "type": "string",
          "description": "Public-safe URL or opaque reference to the participant-visible task envelope."
        },
        "task_envelope": {
          "type": "object",
          "description": "Optional inline participant-visible Task Envelope v2. The real server validates it against task-envelope-v2.schema.json and strips oracle_ref/judge_notes_ref before delivery."
        },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["result_packet", "trace", "evidence_bundle"] }
        },
        "forbidden_actions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["oracle_access", "unapproved_live_mutation", "secret_disclosure"]
          }
        }
      },
      "additionalProperties": false
    }
  }
}
