{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jinwon-int/agent-olympics/schemas/judge-record-v2.schema.json",
  "title": "Agent Olympics Judge Record v2",
  "description": "Judge Record v2 with oracle cross-referencing, evidence verification, and dimension-level notes.",
  "type": "object",
  "required": [
    "schema_version",
    "judge_record_id",
    "task_id",
    "packet_id",
    "judge_type",
    "scoring_rubric",
    "score_dimensions",
    "total_score",
    "verdict",
    "judge_notes"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2,
      "description": "Judge Record schema version. v2 adds oracle_ref, oracle_checks, and dimension_notes."
    },
    "schema_description": {
      "type": "string",
      "description": "Human-readable description of this schema version."
    },
    "judge_record_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "packet_id": { "type": "string", "minLength": 1 },
    "judge_type": {
      "type": "string",
      "enum": ["automated", "human", "llm-assisted", "hybrid"]
    },
    "judge_identity": { "type": "string", "description": "Optional judge name, role, or model identifier." },
    "scoring_rubric": { "type": "string", "minLength": 1 },

    "score_dimensions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["score", "max"],
        "properties": {
          "score": { "type": "number" },
          "max": { "type": "number" },
          "reason": { "type": "string" }
        }
      }
    },
    "total_score": { "type": "number" },

    "oracle_ref": {
      "type": "string",
      "description": "Path to the oracle / answer key file used for judging. Enables traceability between envelope, oracle, result, and judge record."
    },

    "oracle_checks": {
      "type": "array",
      "description": "Per-question comparison between the result packet and the oracle answer key.",
      "items": {
        "type": "object",
        "required": ["question_id", "expected", "actual", "match"],
        "properties": {
          "question_id": { "type": "string" },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "match": {
            "type": "string",
            "enum": ["exact", "partial", "missing", "incorrect"]
          },
          "points_awarded": { "type": "number" },
          "note": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "penalties_applied": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "amount", "reason"],
        "properties": {
          "kind": { "type": "string" },
          "amount": { "type": "number" },
          "reason": { "type": "string" }
        }
      }
    },

    "verdict": {
      "type": "string",
      "enum": ["pass", "conditional_pass", "fail", "disqualification"]
    },

    "judge_notes": { "type": "string", "minLength": 1 },

    "configuration_checks": {
      "type": "object",
      "description": "Optional checks for configuration fitness and provenance. Judges should provide a brief reason for each check to explain the score.",
      "properties": {
        "model_routing_declared": { "type": "boolean" },
        "liveness_declared": { "type": "boolean" },
        "resource_limits_declared": { "type": "boolean" },
        "tool_availability_declared": { "type": "boolean" },
        "context_policy_declared": { "type": "boolean" },
        "concurrency_limits_declared": { "type": "boolean" },
        "notes": { "type": "string", "description": "Judge reasoning for configuration fitness score." }
      },
      "additionalProperties": true
    },

    "operating_policy_checks": {
      "type": "object",
      "description": "Optional checks for approval discipline, secret handling, delegation, and liveness. Judges should include a brief reason explaining the operating discipline score.",
      "properties": {
        "approval_boundaries_checked": { "type": "boolean" },
        "secret_handling_checked": { "type": "boolean" },
        "delegation_disclosed": { "type": "boolean" },
        "progress_reporting_checked": { "type": "boolean" },
        "destructive_action_restraint_checked": { "type": "boolean" },
        "notes": { "type": "string", "description": "Judge reasoning for operating discipline score." }
      },
      "additionalProperties": true
    },

    "division_verification": {
      "type": "object",
      "description": "Optional judge verification of the participant's declared division.",
      "properties": {
        "declared_division": {
          "type": "string",
          "enum": ["closed_stack", "open_stack", "human_baseline", "node_class"]
        },
        "verified": { "type": "boolean" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },

    "appeal_record": {
      "type": "object",
      "description": "Optional appeal review details linked to this judge record.",
      "properties": {
        "appeal_id": { "type": "string" },
        "status": { "type": "string", "enum": ["filed", "under_review", "upheld", "denied", "remanded", "dismissed"] },
        "filed_at": { "type": "string", "format": "date-time" },
        "reviewed_by": { "type": "string" },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "outcome": { "type": "string" },
        "outcome_notes": { "type": "string" }
      },
      "additionalProperties": false
    },

    "dimension_notes": {
      "type": "object",
      "description": "Optional per-dimension free-text notes beyond scores. Judges should write a short reason for each scored dimension, especially for configuration_fitness, operating_discipline, tool_optimization, and reliability_liveness."
    },

    "evidence_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evidence_id": { "type": "string" },
          "verified": { "type": "boolean" },
          "note": { "type": "string" }
        }
      }
    },

    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
