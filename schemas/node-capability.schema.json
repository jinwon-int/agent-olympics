{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jinwon-int/agent-olympics/schemas/node-capability.schema.json",
  "title": "Agent Olympics Node Capability Matrix",
  "description": "A safe, non-secret schema for describing an agent node's capabilities. Designed for cross-node comparison and readiness evaluation. No credential or secret values should appear in a capability document.",
  "type": "object",
  "required": [
    "schema_version",
    "node_id",
    "generated_at",
    "hardware",
    "runtime",
    "tools",
    "services",
    "capability_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "description": "Node capability schema version."
    },
    "node_id": {
      "type": "string",
      "description": "Node label or identifier. Should be anonymizable for blind judging."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this capability report was generated."
    },
    "mission_class": {
      "type": "string",
      "description": "The intended mission class this node was evaluated against."
    },
    "hardware": {
      "type": "object",
      "required": ["cpu", "memory_gb", "os"],
      "properties": {
        "cpu": {
          "description": "CPU class, model, or core count. Examples: 'small-vps', 'Intel Xeon 4-core', 'arm64-8'.",
          "type": "string"
        },
        "memory_gb": {
          "description": "Total system memory in GB.",
          "type": "number",
          "minimum": 0
        },
        "storage": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["nvme", "ssd", "hdd", "unknown"]
            },
            "free_gb": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "os": {
          "type": "object",
          "required": ["family", "kernel"],
          "properties": {
            "family": {
              "type": "string",
              "examples": ["linux", "darwin", "windows"]
            },
            "kernel": {
              "type": "string",
              "examples": ["6.8.0-117-generic"]
            },
            "arch": {
              "type": "string",
              "examples": ["x64", "arm64"]
            }
          }
        },
        "gpu": {
          "type": "object",
          "properties": {
            "available": { "type": "boolean" },
            "model": { "type": "string" },
            "vram_gb": { "type": "number" }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "required": ["type", "version"],
      "properties": {
        "type": {
          "type": "string",
          "examples": ["openclaw", "hermes", "codex", "cli"]
        },
        "version": {
          "type": "string",
          "examples": ["2026.5.26", "1.0.0"]
        },
        "workspace_path": {
          "type": "string",
          "description": "Workspace directory path (no secret content)."
        },
        "config_files": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Non-secret config file paths. Do not include credential files."
        },
        "model_routing": {
          "type": "object",
          "properties": {
            "primary_provider": { "type": "string" },
            "primary_model": { "type": "string" },
            "fallback_available": { "type": "boolean" }
          }
        }
      }
    },
    "tools": {
      "type": "object",
      "required": ["available", "count"],
      "properties": {
        "available": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "available"],
            "properties": {
              "name": { "type": "string" },
              "available": { "type": "boolean" },
              "category": {
                "type": "string",
                "enum": ["file-io", "exec", "network", "knowledge", "communication", "config", "agent-ops", "other"]
              }
            }
          }
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "missing_critical": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Names of tools that are essential but missing."
        }
      }
    },
    "services": {
      "type": "object",
      "properties": {
        "gateway": {
          "type": "object",
          "properties": {
            "alive": { "type": "boolean" },
            "uptime_seconds": { "type": "number" },
            "listening": { "type": "string" }
          }
        },
        "node_agent": {
          "type": "object",
          "properties": {
            "connected": { "type": "boolean" },
            "type": { "type": "string" }
          }
        },
        "other_services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["running", "stopped", "unknown"]
              }
            }
          }
        }
      }
    },
    "capability_summary": {
      "type": "object",
      "required": ["overall_readiness", "gaps", "recommendations"],
      "properties": {
        "overall_readiness": {
          "type": "string",
          "enum": ["ready", "ready_with_caveats", "not_ready", "unknown"]
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "area": { "type": "string" },
              "description": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["blocker", "warning", "info"]
              }
            }
          }
        },
        "recommendations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "score_estimate": {
          "type": "object",
          "properties": {
            "dimension": { "type": "string" },
            "score": { "type": "number" },
            "max": { "type": "number", "const": 100 }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "generated_by_event": { "type": "string" },
        "run_id": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
