{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jinwon-int/agent-olympics/schemas/result-packet-v2.schema.json",
  "title": "Agent Olympics Result Packet v2",
  "description": "Result Packet v2 with enhanced evidence tracking, oracle cross-referencing, and migration metadata.",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "agent_id",
    "runtime",
    "started_at",
    "ended_at",
    "status",
    "summary",
    "evidence",
    "findings",
    "outputs"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 2,
      "description": "Result Packet schema version. v2 adds oracle_ref, v1_compat, and enhanced evidence fields."
    },
    "schema_description": {
      "type": "string",
      "description": "Human-readable description of this schema version."
    },
    "packet_id": { "type": "string", "minLength": 1, "description": "Unique packet identifier for judge cross-referencing." },
    "task_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "agent_version": { "type": "string", "description": "Agent software version." },
    "runtime": { "type": "string", "minLength": 1 },
    "runtime_version": { "type": "string", "description": "Runtime version." },
    "model": { "type": "string" },
    "node": { "type": "string" },
    "hardware_profile": { "type": "object" },
    "configuration_profile": { "type": "object" },
    "workload_metrics": { "type": "object" },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["completed", "partial", "blocked", "failed", "disqualified"]
    },
    "summary": { "type": "string", "minLength": 1 },

    "oracle_ref": {
      "type": "string",
      "description": "Optional reference to the oracle file that was used for this task. Enables automated cross-referencing between result packets and answer keys."
    },

    "v1_compat": {
      "type": "object",
      "description": "Migration metadata when a v1 result packet is upgraded to v2.",
      "properties": {
        "original_packet_id": { "type": "string" },
        "converted_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },

    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "target": { "type": "string" },
          "command_summary": { "type": "string" },
          "redacted": { "type": "boolean" },
          "evidence_id": { "type": "string" },
          "duration_seconds": { "type": "number" },
          "result": { "type": "string" },
          "oracle_question_id": {
            "type": "string",
            "description": "Optional reference to a specific oracle question/check this action addresses."
          }
        }
      }
    },

    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "summary"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "source": { "type": "string" },
          "summary": { "type": "string" },
          "content_ref": { "type": "string", "description": "Path or URL to full evidence content." },
          "tag": {
            "type": "string",
            "description": "Optional categorization tag for evidence (e.g., 'redacted', 'oracle-match', 'contradiction')."
          }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },

    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "evidence"],
        "properties": {
          "claim": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "oracle_match": {
            "type": "string",
            "enum": ["expected", "partial", "unexpected"],
            "description": "How this finding relates to the oracle answer key. Filled by judge tooling, not by participants."
          }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },

    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },

    "outputs": { "type": "object" },

    "communication_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "channel": { "type": "string" },
          "summary": { "type": "string" },
          "redacted": { "type": "boolean" }
        }
      },
      "description": "Optional log of user-facing communication during the task."
    }
  },
  "additionalProperties": false
}
