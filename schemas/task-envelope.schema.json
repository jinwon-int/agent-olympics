{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jinwon-int/agent-olympics/schemas/task-envelope.schema.json",
  "title": "Agent Olympics Task Envelope",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "title",
    "event_family",
    "category",
    "time_limit_minutes",
    "objective",
    "allowed_actions",
    "forbidden_actions",
    "required_outputs",
    "scoring_rubric"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "event_family": {
      "type": "string",
      "enum": [
        "ops-relay",
        "node-readiness",
        "performance-trial",
        "code-sprint",
        "wiki-marathon",
        "safety-trial",
        "coordination-drill"
      ]
    },
    "category": { "type": "string", "minLength": 1 },
    "time_limit_minutes": { "type": "integer", "minimum": 1 },
    "participant_visibility": {
      "type": "string",
      "enum": ["visible", "blind", "internal"],
      "default": "visible"
    },
    "objective": { "type": "string", "minLength": 1 },
    "evaluation_focus": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "mission_execution",
          "configuration_fitness",
          "hardware_capacity",
          "resource_efficiency",
          "safety",
          "durability",
          "communication"
        ]
      }
    },
    "background": { "type": "string" },
    "environment": { "type": "object" },
    "hardware_profile": { "type": "object" },
    "baseline_profile": { "type": "object" },
    "fixtures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_actions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "forbidden_actions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "required_outputs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "scoring_rubric": { "type": "string", "minLength": 1 },
    "labels": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hidden_judge_notes": { "type": "string" },
    "expected_artifacts": {
      "type": "object",
      "description": "Expected artifacts and their required-or-optional status."
    },
    "approval_policy": {
      "type": "string",
      "description": "Describes which actions require explicit approval before execution."
    },
    "cost_limit": {
      "type": "object",
      "description": "Maximum allowed cost (e.g., USD, tokens, API calls).",
      "properties": {
        "max_cost_usd": { "type": "number", "minimum": 0 },
        "max_tokens": { "type": "integer", "minimum": 0 },
        "max_api_calls": { "type": "integer", "minimum": 0 }
      }
    },
    "model_visibility_policy": {
      "type": "string",
      "enum": ["required", "optional", "hidden"],
      "description": "Whether the participant model identity must be reported."
    },
    "transcript_policy": {
      "type": "string",
      "description": "Whether and how the participant transcript should be preserved for judging."
    }
  },
  "additionalProperties": true
}
