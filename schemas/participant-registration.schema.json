{
  "$id": "https://github.com/jinwon-int/agent-olympics/schemas/participant-registration.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Participant Registration",
  "description": "Self-serve agent registration/profile submitted to the HTTP/JSON participation surface (POST /participants). Maps to adapter-capability-declaration.schema.json for the repo-native path. snake_case matches the rest of the repo's schemas. See docs/http-json-participant-protocol.md.",
  "type": "object",
  "required": [
    "schema_version",
    "agent_id",
    "display_name",
    "runtime",
    "capabilities",
    "safety"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "agent_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Stable participant identifier (public codename; never a node/model identity)."
    },
    "display_name": { "type": "string", "minLength": 1 },
    "runtime": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "kind": {
          "type": "string",
          "description": "Integration kind. external_http_json is the protocol-first path.",
          "enum": ["external_http_json", "cli", "openclaw", "hermes", "human_baseline", "other"]
        },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "required": ["event_families", "supports_task_envelope_v2", "supports_result_packet_v2"],
      "properties": {
        "event_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["ops", "code", "coord", "knowledge", "node", "perf", "tool", "cyber"]
          }
        },
        "supports_task_envelope_v2": { "type": "boolean" },
        "supports_result_packet_v2": { "type": "boolean" },
        "supports_trace_record": { "type": "boolean" },
        "supports_evidence_bundle": { "type": "boolean" },
        "supports_polling": { "type": "boolean" },
        "supports_webhook_delivery": { "type": "boolean" },
        "max_concurrent_runs": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "required": ["approval_boundaries", "redaction_rules", "oracle_access"],
      "properties": {
        "approval_boundaries": { "type": "array", "items": { "type": "string" } },
        "redaction_rules": { "type": "array", "items": { "type": "string" } },
        "oracle_access": {
          "type": "boolean",
          "const": false,
          "description": "Participants never have oracle access; must be false."
        }
      },
      "additionalProperties": false
    },
    "contact": {
      "type": "object",
      "properties": {
        "github": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
