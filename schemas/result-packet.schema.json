{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jinwon-int/agent-olympics/schemas/result-packet.schema.json",
  "title": "Agent Olympics Result Packet",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "agent_id",
    "runtime",
    "started_at",
    "ended_at",
    "status",
    "summary",
    "evidence",
    "findings",
    "outputs"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1, "description": "Unique packet identifier for judge cross-referencing." },
    "task_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "agent_version": { "type": "string", "description": "Agent software version." },
    "runtime": { "type": "string", "minLength": 1 },
    "runtime_version": { "type": "string", "description": "Runtime version." },
    "model": { "type": "string" },
    "node": { "type": "string" },
    "hardware_profile": { "type": "object" },
    "configuration_profile": { "type": "object" },
    "workload_metrics": { "type": "object" },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["completed", "partial", "blocked", "failed", "disqualified"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "target": { "type": "string" },
          "command_summary": { "type": "string" },
          "redacted": { "type": "boolean" },
          "evidence_id": { "type": "string" },
          "duration_seconds": { "type": "number" },
          "result": { "type": "string" }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "summary"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "source": { "type": "string" },
          "summary": { "type": "string" },
          "content_ref": { "type": "string", "description": "Path or URL to full evidence content." }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "evidence"],
        "properties": {
          "claim": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": { "type": "object" },
    "communication_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "channel": { "type": "string" },
          "summary": { "type": "string" }
        }
      },
      "description": "Optional log of user-facing communication during the task."
    }
  },
  "additionalProperties": true
}
