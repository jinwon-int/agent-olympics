{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jinwon-int/agent-olympics/schemas/result-packet.schema.json",
  "title": "Agent Olympics Result Packet",
  "description": "Standard output format submitted by each participant. Contains status, summary, evidence, findings, and outputs. May reference an external trace record and evidence bundle via run_id. Redaction fields (redacted, redaction_reason) describe what was removed — never the secret value itself.",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "agent_id",
    "runtime",
    "started_at",
    "ended_at",
    "status",
    "summary",
    "evidence",
    "findings",
    "outputs"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "packet_id": { "type": "string", "minLength": 1, "description": "Unique packet identifier for judge cross-referencing." },
    "run_id": { "type": "string", "minLength": 1, "description": "Links to an external run result and evidence bundle." },
    "task_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "agent_version": { "type": "string", "description": "Agent software version." },
    "runtime": { "type": "string", "minLength": 1 },
    "runtime_version": { "type": "string", "description": "Runtime version." },
    "model": { "type": "string" },
    "node": { "type": "string" },
    "hardware_profile": { "type": "object" },
    "configuration_profile": { "type": "object" },
    "tool_use_profile": { "type": "object" },
    "operating_policy": { "type": "object" },
    "delegation_profile": { "type": "object" },
    "workload_metrics": { "type": "object" },
    "division": {
      "type": "string",
      "enum": ["closed_stack", "open_stack", "human_baseline", "node_class"],
      "description": "Competition division. Defaults to open_stack if not declared."
    },
    "validity": {
      "type": "string",
      "enum": ["valid", "partial_valid", "invalid", "appealed", "disqualified"],
      "description": "Result validity state. Set by round engine after validation and judging."
    },
    "appeal": {
      "type": "object",
      "description": "Appeal record when this result is challenged. Present only during or after an appeal.",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["filed", "under_review", "upheld", "denied", "remanded", "dismissed"]
        },
        "filed_at": { "type": "string", "format": "date-time" },
        "filed_by": { "type": "string", "description": "Identity of the filer (participant, judge, or curator)." },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to supporting evidence (rule numbers, trace entries, evidence IDs)."
        },
        "reviewed_by": { "type": "string", "description": "Identity of the reviewer." },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "outcome": { "type": "string", "description": "Final appeal decision." },
        "outcome_notes": { "type": "string", "description": "Short explanation of the outcome." }
      },
      "additionalProperties": false
    },
    "publishable": {
      "type": "boolean",
      "description": "Whether this packet is safe to expose in public leaderboard/detail output."
    },
    "started_at": { "type": "string", "format": "date-time" },
    "ended_at": { "type": "string", "format": "date-time" },
    "status": {
      "type": "string",
      "enum": ["completed", "partial", "blocked", "failed", "disqualified"]
    },
    "summary": { "type": "string", "minLength": 1 },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "target": { "type": "string" },
          "command_summary": { "type": "string" },
          "redacted": {
            "type": "boolean",
            "description": "True if action output or arguments contained sensitive data."
          },
          "redaction_reason": {
            "type": "string",
            "description": "Value-free reason for redaction, e.g. 'command_output_contained_api_token'. Must not include the actual secret value."
          },
          "evidence_id": { "type": "string" },
          "duration_seconds": { "type": "number" },
          "result": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "summary"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string" },
          "source": { "type": "string" },
          "summary": { "type": "string" },
          "redacted": {
            "type": "boolean",
            "description": "True if the evidence summary or referenced content contains redacted material."
          },
          "redaction_reason": {
            "type": "string",
            "description": "Value-free reason for redaction. Must not include the actual secret value."
          },
          "content_ref": { "type": "string", "description": "Path or URL to full evidence content." }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "evidence"],
        "properties": {
          "claim": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        },
        "additionalProperties": true
      },
      "minItems": 1
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": { "type": "object" },
    "communication_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "channel": { "type": "string" },
          "summary": { "type": "string" },
          "redacted": {
            "type": "boolean",
            "description": "True if the communication summary contains redacted material."
          },
          "redaction_reason": {
            "type": "string",
            "description": "Value-free reason for redaction."
          }
        },
        "additionalProperties": false
      },
      "description": "Optional log of user-facing communication during the task."
    }
  },
  "additionalProperties": true
}
