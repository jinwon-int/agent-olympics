{
  "name": "agent-olympics",
  "version": "1.0.0",
  "private": true,
  "description": "Agent Olympics — platform-neutral agent competition schemas and validation",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "validate:envelopes": "node scripts/validate.js envelopes",
    "validate:packets": "node scripts/validate.js packets",
    "validate:fixtures": "node scripts/validate.js fixtures",
    "validate:rounds": "node scripts/validate.js rounds",
    "validate:all": "node scripts/validate.js all",
    "validate:a2a_effectiveness": "node scripts/validate-a2a-effectiveness.js",
    "ci:round": "node scripts/ci-round.js",
    "live-runner:readiness": "node scripts/live-runner-readiness.js",
    "live-runner": "node scripts/live-runner.js",
    "test:live_runner_readiness": "node scripts/live-runner-readiness.js fixtures/live-runner-readiness/blocked-missing-approval.yaml --expect blocked && node scripts/live-runner-readiness.js fixtures/live-runner-readiness/dry-run-ready.yaml --expect ready",
    "test:live_runner_fixtures": "node scripts/live-runner.js fixtures",
    "test:coordination_fixtures": "node scripts/coordination-round.js fixtures",
    "coordination-round": "node scripts/coordination-round.js",
    "test:round_hardening": "bash scripts/test-round-hardening.sh",
    "test:declaration_cross_check": "node scripts/declaration-cross-check.js",
    "test:proof_token_verify": "node scripts/proof-token-verify.js",
    "test:safety_trial_verify": "node scripts/safety-trial-verify.js fixtures",
    "test:judge_fixtures": "node scripts/judge.js fixtures",
    "test:mission_toolsets": "node scripts/lib/mission-toolsets.js selftest",
    "test:appeal_fixtures": "node scripts/appeal.js fixtures",
    "test:longitudinal_fixtures": "node scripts/longitudinal.js fixtures",
    "test:human_baseline_fixtures": "node scripts/human-baseline.js fixtures",
    "appeal": "node scripts/appeal.js",
    "longitudinal": "node scripts/longitudinal.js",
    "round": "node scripts/round.js",
    "test:participant_protocol": "node scripts/validate-participant-protocol.js",
    "test:participant_server": "node --test test/participant-server.test.js",
    "participant-protocol-mock": "node scripts/participant-protocol-mock.js",
    "participant-server": "node scripts/participant-server.js serve",
    "participant-review": "node scripts/participant-server.js review",
    "lint": "eslint scripts/ adapters/ test/ eslint.config.js",
    "format": "prettier --write \"scripts/**/*.js\" \"adapters/**/*.js\" \"test/**/*.js\" \"*.js\"",
    "format:check": "prettier --check \"scripts/**/*.js\" \"adapters/**/*.js\" \"test/**/*.js\" \"*.js\"",
    "test:unit": "node --test test/*.test.js",
    "test": "node --test test/*.test.js && node scripts/validate.js all && node scripts/validate-a2a-effectiveness.js"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "globals": "^14.0.0",
    "prettier": "^3.9.4"
  }
}
